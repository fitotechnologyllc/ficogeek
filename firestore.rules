rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HIGHER ORDER HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (getProfile().role == 'admin' || request.auth.uid == 'ZbwjSWuunZYQAMtLWLgjB4ezQqh2');
    }

    function isOwnerRole() {
      return isSignedIn() && getProfile().role == 'owner';
    }

    function isAdminOrOwner() {
      return isAdmin() || isOwnerRole();
    }

    function isPro() {
      return isSignedIn() && getProfile().role == 'pro';
    }

    function isDocOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // FIELD VALIDATION HELPERS
    function isUnchanged(field) {
      return !(field in request.resource.data) || (field in resource.data && request.resource.data[field] == resource.data[field]);
    }

    // --- COLLECTIONS ---

    match /profiles/{userId} {
      allow read: if isSignedIn() && (isDocOwner(userId) || isAdminOrOwner());
      allow create: if isSignedIn() && isDocOwner(userId) && 
                      (request.resource.data.role == 'personal' || request.resource.data.role == 'pro') && 
                      request.resource.data.status == 'Active';
      allow update: if isSignedIn() && (
                      (isDocOwner(userId) && 
                       isUnchanged('role') && 
                       isUnchanged('status') && 
                       isUnchanged('isPartner') &&
                       isUnchanged('twoFactorEnabled') &&
                       isUnchanged('twoFactorSecretEncrypted') &&
                       isUnchanged('twoFactorEnrolledAt')) || 
                      isAdminOrOwner()
                    );
      allow delete: if isAdminOrOwner();
    }

    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUID == request.auth.uid || 
        resource.data.proUID == request.auth.uid ||
        isAdminOrOwner()
      );
      allow create: if isSignedIn() && (
        request.resource.data.ownerUID == request.auth.uid || 
        (isPro() && request.resource.data.proUID == request.auth.uid) ||
        isOwnerRole()
      );
      allow update: if isSignedIn() && (
        (resource.data.ownerUID == request.auth.uid && isUnchanged('ownerUID') && isUnchanged('proUID')) || 
        (resource.data.proUID == request.auth.uid && isUnchanged('proUID') && isUnchanged('ownerUID')) ||
        isAdminOrOwner()
      );
      allow delete: if isSignedIn() && (
        resource.data.ownerUID == request.auth.uid || 
        isAdminOrOwner()
      );
    }

    match /documents/{docId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUID == request.auth.uid || 
        resource.data.proUID == request.auth.uid ||
        isAdminOrOwner()
      );
      allow create: if isSignedIn() && (
        request.resource.data.ownerUID == request.auth.uid || 
        (isPro() && request.resource.data.proUID == request.auth.uid) ||
        isOwnerRole()
      );
      allow update: if isSignedIn() && (
        (resource.data.ownerUID == request.auth.uid && isUnchanged('ownerUID')) || 
        (resource.data.proUID == request.auth.uid && isUnchanged('proUID')) ||
        isAdminOrOwner()
      );
      allow delete: if isSignedIn() && (resource.data.ownerUID == request.auth.uid || isAdminOrOwner());
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (resource.data.proUID == request.auth.uid || isAdminOrOwner());
      allow create: if (isPro() && request.resource.data.proUID == request.auth.uid) || isOwnerRole();
      allow update: if (isPro() && resource.data.proUID == request.auth.uid && isUnchanged('proUID')) || isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    match /letters/{letterId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUID == request.auth.uid || 
        resource.data.proUID == request.auth.uid ||
        isAdminOrOwner()
      );
      allow create: if isSignedIn() && (
        request.resource.data.ownerUID == request.auth.uid || 
        (isPro() && request.resource.data.proUID == request.auth.uid) ||
        isOwnerRole()
      );
      allow update: if isSignedIn() && (
        (resource.data.ownerUID == request.auth.uid && isUnchanged('ownerUID')) || 
        (resource.data.proUID == request.auth.uid && isUnchanged('proUID')) ||
        isAdminOrOwner()
      );
      allow delete: if isAdminOrOwner();
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrOwner();
    }

    match /audit_logs/{logId} {
      allow read: if isAdminOrOwner();
      allow create: if isSignedIn() && 
                    request.resource.data.actorUID == request.auth.uid &&
                    request.resource.data.timestamp == request.time;
      allow update, delete: if false; 
    }

    match /promo_codes/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrOwner();
    }

    match /promo_redemptions/{redemptionId} {
      allow read: if isSignedIn() && (isDocOwner(redemptionId.split('_')[0]) || isAdminOrOwner());
      allow write: if false; // Managed by server action
    }

    match /partners/{partnerId} {
      allow read: if isSignedIn() && (isDocOwner(partnerId) || isAdminOrOwner());
      allow create: if isSignedIn() && isDocOwner(partnerId);
      allow update: if isAdminOrOwner();
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn() && (resource.data.partnerUID == request.auth.uid || isAdminOrOwner());
      allow create: if isSignedIn();
      allow update: if isAdminOrOwner();
    }

    match /commissions/{commissionId} {
      allow read: if isSignedIn() && (resource.data.partnerUID == request.auth.uid || isAdminOrOwner());
      allow write: if isAdminOrOwner();
    }

    match /payouts/{payoutId} {
      allow read: if isSignedIn() && (resource.data.partnerUID == request.auth.uid || isAdminOrOwner());
      allow create: if isSignedIn() && request.resource.data.partnerUID == request.auth.uid;
      allow update: if isAdminOrOwner();
    }

    match /coupon_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrOwner();
    }
    
    match /referral_clicks/{clickId} {
      allow read: if isAdminOrOwner();
      allow create: if true;
    }

    match /ai_conversations/{convId} {
      allow read: if isSignedIn() && (resource.data.ownerUID == request.auth.uid || isAdminOrOwner());
      allow create: if isSignedIn() && (request.resource.data.ownerUID == request.auth.uid || isOwnerRole());
      allow update: if isSignedIn() && (resource.data.ownerUID == request.auth.uid || isAdminOrOwner());
      allow delete: if isSignedIn() && (resource.data.ownerUID == request.auth.uid || isAdminOrOwner());
    }

    match /ai_messages/{msgId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/ai_conversations/$(resource.data.conversationId)).data.ownerUID == request.auth.uid || 
        isAdminOrOwner()
      );
      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/ai_conversations/$(request.resource.data.conversationId)).data.ownerUID == request.auth.uid ||
        isOwnerRole()
      );
    }

    match /ai_dispute_intakes/{intakeId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUID == request.auth.uid || 
        resource.data.proUID == request.auth.uid || 
        isAdminOrOwner()
      );
      allow create: if isSignedIn() && (
        request.resource.data.ownerUID == request.auth.uid || 
        (isPro() && request.resource.data.proUID == request.auth.uid) ||
        isOwnerRole()
      );
      allow update: if isSignedIn() && (
        resource.data.ownerUID == request.auth.uid || 
        resource.data.proUID == request.auth.uid || 
        isAdminOrOwner()
      );
    }

    match /ai_knowledge/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrOwner();
    }
  }
}
